<%# Generates an Article-type page that follows WBEZ editorial layout patterns. %>
class <%= controller_class_name %> < ApplicationController
  def show
    @kicker = "<%= plural_name.humanize %>"
    @title = "<%= name %>"
    @dek = "A WBEZ-style Bootstrap editorial page generated by wbez:page."
    @byline = "WBEZ Bootstrap Starter"
    @published_at = "March 2026"
    @figure_caption = "Lead image placeholder with caption and credit treatment."
  end
end

