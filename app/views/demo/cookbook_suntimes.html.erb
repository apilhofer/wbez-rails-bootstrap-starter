<div class="bg-white suntimes-prototype">
  <%= render "shared/ui/site_header_suntimes" %>
  <main class="content-shell px-3 py-4 suntimes-home--visily">
    <header class="mb-5">
      <div class="suntimes-home__category mb-2">Editorial patterns</div>
      <h1 class="suntimes-home__headline-xl">Sun-Times Cookbook</h1>
      <p class="suntimes-home__meta mb-0">Reference recipes for homepage rails, category bands, and article rhythm modules.</p>
    </header>

    <section class="mb-5">
      <%= render "shared/ui/section_header", title: "Homepage hero + latest rail" %>
      <%= render "shared/ui/suntimes/home/hero" %>
    </section>

    <section class="mb-5">
      <%= render "shared/ui/section_header", title: "Category band recipe" %>
      <%= render "shared/ui/suntimes/home/chicago" %>
    </section>

    <section class="mb-5">
      <%= render "shared/ui/section_header", title: "Newsletter recipe" %>
      <%= render "shared/ui/suntimes/home/newsletter" %>
    </section>
  </main>

  <%= render "shared/ui/full_width_promo_spot",
    heading_id: "cookbook-suntimes-full-width-promo-heading",
    homepage_slot: "bottom-full-width-promo",
    graphic_placeholder: true,
    promo: {
      title: "The Chicago Sun-Times is reader-funded",
      body: "Local journalism depends on subscribers. Support investigative reporting, breaking news, and the stories that shape Chicago.",
      button: "Subscribe",
      href: "#"
    } %>

  <%= render "shared/ui/site_footer_suntimes" %>
</div>
