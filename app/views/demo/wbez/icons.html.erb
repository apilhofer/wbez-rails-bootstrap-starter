<div class="bg-white wbez-prototype">
  <%= render "shared/ui/wbez/site_header" %>

  <main class="content-shell px-3 py-4">
    <header class="mb-5">
      <div class="wbez-kicker mb-2">Brand assets</div>
      <h1 class="editorial-heading display-5">Icons demo</h1>
      <p class="lead">These icons are installed locally so the app can use official icon assets.</p>
    </header>

    <%= render "shared/ui/section_header", title: "WBEZ icons" %>
    <div class="row g-4 mb-5">
      <% @wbez_icons.each do |name, asset_name| %>
        <div class="col-6 col-md-4 col-xl-3">
          <div class="card wbez-card h-100">
            <div class="card-body">
              <div class="story-kicker mb-2"><%= name %></div>
              <div class="border rounded bg-light p-3 d-flex align-items-center justify-content-center" style="min-height: 90px;">
                <%= ferris_icon name, set: "wbez", size: 28 %>
              </div>
              <div class="story-meta mt-3"><code><%= asset_name %></code></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%= render "shared/ui/section_header", title: "Marketing icons" %>
    <div class="row g-4">
      <% @marketing_icons.each do |name, asset_name| %>
        <div class="col-6 col-md-4 col-xl-3">
          <div class="card wbez-card h-100">
            <div class="card-body">
              <div class="story-kicker mb-2"><%= name %></div>
              <div class="border rounded bg-light p-3 d-flex align-items-center justify-content-center" style="min-height: 90px;">
                <%= ferris_icon name, set: "marketing", size: 28 %>
              </div>
              <div class="story-meta mt-3"><code><%= asset_name %></code></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </main>

  <%= render "shared/ui/wbez/site_footer" %>
</div>
