<div class="bg-white wbez-prototype">
  <%= render "shared/ui/wbez/site_header" %>

  <main class="content-shell px-3 py-4">
    <section class="my-4">
      <%= render "shared/ui/hero_story", kicker: @lead_story[:kicker], title: @lead_story[:title], dek: @lead_story[:dek] %>
    </section>

    <section class="my-5">
      <%= render "shared/ui/bsp_list_loadmore_featured_audio",
        items: [
          { kicker: "Classical", title: "Lorem ipsum story headline for audio slot one" },
          { kicker: "Education", title: "Ut enim ad minim veniam quis nostrud exercitation ullam" },
          { kicker: "Technology", title: "Duis aute irure dolor in reprehenderit in voluptate" },
          { kicker: "Theater & Stages", title: "Excepteur sint occaecat cupidatat non proident sunt" }
        ] %>
    </section>

    <section class="my-5">
      <%= render "shared/ui/embed_module",
        title: "Accurate Information. Reliable Reporting. Diverse Perspectives.",
        button_text: "Donate",
        href: "#" %>
    </section>
  </main>

  <%= render "shared/ui/wbez/site_footer" %>
</div>
