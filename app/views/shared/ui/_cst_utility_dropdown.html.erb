<%# locals: label (String), items (Array<[title, href]>), align (optional :end), tone (optional :dark for black text) %>
<% align = local_assigns.fetch(:align, :start) %>
<% tone = local_assigns.fetch(:tone, :muted) %>
<div class="dropdown cst-dropdown cst-dropdown--utility">
  <button
    class="btn btn-link dropdown-toggle cst-dropdown__toggle <%= tone == :dark ? "text-dark" : "text-secondary" %> text-decoration-none py-0 px-1 small shadow-none"
    type="button"
    data-bs-toggle="dropdown"
    data-bs-auto-close="true"
    aria-expanded="false">
    <%= label %>
  </button>
  <ul class="dropdown-menu small <%= "dropdown-menu-end" if align == :end %>">
    <% items.each do |title, href| %>
      <li><%= link_to title, href, class: "dropdown-item" %></li>
    <% end %>
  </ul>
</div>
