<section class="mb-5" data-homepage-slot="suntimes-opinion-four-rails">
  <div class="row g-4 g-lg-5 align-items-start">
    <% rails.each do |rail| %>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="suntimes-home__section-accent">
          <h2 class="suntimes-home__section-title"><%= rail[:title] %></h2>
        </div>
        <%= render "shared/ui/suntimes/home/one_column_section_zone", items: rail[:items] %>
      </div>
    <% end %>
  </div>
</section>

