#!/usr/bin/env bash
# Print sorted unique data-homepage-slot values from saved homepage HTML.
# Usage: bin/wbez-compare-homepage path/to/page.html
set -euo pipefail
if [[ $# -lt 1 ]] || [[ ! -f "$1" ]]; then
  echo "Usage: $0 path/to/saved-homepage.html" >&2
  exit 1
fi
grep -o 'data-homepage-slot="[^"]*"' "$1" | sort -u
